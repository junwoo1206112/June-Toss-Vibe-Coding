# Supabase 설정 (https://supabase.com에서 프로젝트 생성 후 입력)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 운영에서는 필수입니다. Supabase meal-api Edge Function URL을 입력하세요.
# 예: https://your-project.supabase.co/functions/v1/meal-api
VITE_MEAL_API_URL=https://your-project.supabase.co/functions/v1/meal-api

# 사업자 인증과 토스 로그인 콘솔 설정이 완료된 경우에만 true로 변경하세요.
VITE_ENABLE_TOSS_LOGIN=false
